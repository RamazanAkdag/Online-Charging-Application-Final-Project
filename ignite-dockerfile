FROM eclipse-temurin:17-jdk

ENV IGNITE_VERSION 2.16.0

ENV IGNITE_HOME /opt/ignite/apache-ignite-fabric-${IGNITE_VERSION}-bin

RUN apt-get update && apt-get install -y --no-install-recommends \
        unzip \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/ignite

RUN curl https://dist.apache.org/repos/dist/release/ignite/${IGNITE_VERSION}/apache-ignite-fabric-${IGNITE_VERSION}-bin.zip -o ignite.zip \
    && unzip ignite.zip \
    && rm ignite.zip

COPY ./ignite-config.xml $IGNITE_HOME/config/
COPY ./igniterun.sh $IGNITE_HOME/

RUN chmod +x $IGNITE_HOME/igniterun.sh

CMD $IGNITE_HOME/igniterun.sh

EXPOSE 11211 47100 47500 49112
