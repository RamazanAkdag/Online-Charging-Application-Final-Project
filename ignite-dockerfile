FROM eclipse-temurin:17-jdk

# Ignite sürümü
ENV IGNITE_VERSION=2.16.0

# Ignite Home Dizini
ENV IGNITE_HOME=/opt/ignite

# Gerekli bağımlılıkları yükle
RUN apt-get update && apt-get install -y --no-install-recommends \
        unzip \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Çalışma dizinini ayarla
WORKDIR /opt

# Apache Ignite'ı indir ve çıkar
RUN curl -L https://archive.apache.org/dist/ignite/${IGNITE_VERSION}/apache-ignite-${IGNITE_VERSION}-bin.zip -o ignite.zip \
    && unzip ignite.zip \
    && mv apache-ignite-${IGNITE_VERSION}-bin $IGNITE_HOME \
    && rm ignite.zip

# Çalışma dizinini Ignite dizinine ayarla
WORKDIR $IGNITE_HOME

# Ignite konfigürasyon dosyasını kopyala
COPY ignite-config.xml /opt/ignite/config/

# Ignite için gerekli portları aç
EXPOSE 10800 47100 47500 49112 8080

# Ignite'ı başlat
CMD ["bin/ignite.sh", "config/ignite-config.xml"]

