FROM eclipse-temurin:17-jdk

# Ignite sürümü
ENV IGNITE_VERSION 2.16.0

# Ignite Home Dizini
ENV IGNITE_HOME /opt/ignite/apache-ignite-${IGNITE_VERSION}-bin

# Gerekli bağımlılıkları yükle
RUN apt-get update && apt-get install -y --no-install-recommends \
        unzip \
        curl \
    && rm -rf /var/lib/apt/lists/*

# Çalışma dizinini ayarla
WORKDIR /opt/ignite

# Apache Ignite'ı indir ve çıkar
RUN curl -L https://archive.apache.org/dist/ignite/${IGNITE_VERSION}/apache-ignite-${IGNITE_VERSION}-bin.zip -o ignite.zip \
    && unzip ignite.zip \
    && rm ignite.zip

# Konfigürasyon dosyalarını Ignite dizinine kopyala
COPY ./ignite-config.xml $IGNITE_HOME/config/
COPY ./igniterun.sh $IGNITE_HOME/

# Çalıştırma dosyasına izin ver
RUN chmod +x $IGNITE_HOME/igniterun.sh

# Ignite'ı başlat
CMD ["sh", "-c", "$IGNITE_HOME/igniterun.sh"]

# Ignite için gerekli portları aç
EXPOSE 11211 47100 47500 49112
