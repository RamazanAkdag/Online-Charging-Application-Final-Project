<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Ignite Konfigürasyonu -->
    <bean id="ignite.cfg" class="org.apache.ignite.configuration.IgniteConfiguration">
        <!-- Cluster ismi -->
        <property name="igniteInstanceName" value="ignite-cluster"/>

        <!-- Tüm ağ arayüzlerinden dinlemesi için ayarlar -->
        <property name="localHost" value="0.0.0.0"/>

        <!-- Discovery SPI (Cluster oluşturmak için) -->
        <property name="discoverySpi">
            <bean class="org.apache.ignite.spi.discovery.tcp.TcpDiscoverySpi">
                <property name="ipFinder">
                    <bean class="org.apache.ignite.spi.discovery.tcp.ipfinder.vm.TcpDiscoveryVmIpFinder">
                        <property name="addresses">
                            <list>
                                <!-- Ignite’ın tüm ağ arayüzlerinden gelen istekleri kabul etmesini sağlar -->
                                <value>0.0.0.0:47500..47509</value>
                            </list>
                        </property>
                    </bean>
                </property>
                <property name="localAddress" value="0.0.0.0"/>
            </bean>
        </property>

        <!-- Komşu düğümleri otomatik bulmak için Multicast Discovery -->
        <property name="discoverySpi">
            <bean class="org.apache.ignite.spi.discovery.tcp.TcpDiscoverySpi">
                <property name="ipFinder">
                    <bean class="org.apache.ignite.spi.discovery.tcp.ipfinder.multicast.TcpDiscoveryMulticastIpFinder">
                        <property name="multicastGroup" value="228.10.10.157"/>
                    </bean>
                </property>
            </bean>
        </property>
    </bean>

</beans>
